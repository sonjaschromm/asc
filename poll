<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reader Poll — ASC | Object. Power. Culture.</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Karla:wght@300;400;500&display=swap" rel="stylesheet">
<style>

* { margin:0; padding:0; box-sizing:border-box; }
body {
  background: #0e0b06; min-height: 100vh;
  font-family: 'Karla', sans-serif; color: #f0ead8;
  padding: 2rem 1rem 4rem;
  font-size: 16px;
}
.wrap { max-width: 640px; margin: 0 auto; }
.back {
  display: inline-flex; align-items: center; gap: 0.5rem;
  font-size: 13px; letter-spacing: 0.15em; text-transform: uppercase;
  color: #b8923a; text-decoration: none; margin-bottom: 2rem;
  transition: opacity 0.2s;
}
.back:hover { opacity: 0.7; }
.card {
  background: linear-gradient(160deg, #1a1408 0%, #110d05 60%, #0e0b06 100%);
  border: 1px solid rgba(184,146,58,0.2);
  position: relative; overflow: hidden;
  box-shadow: 0 2px 40px rgba(0,0,0,0.4);
}
.card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, transparent, #b8923a, #d4aa5a, #b8923a, transparent);
}
.eyebrow { font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase; color: #b8923a; margin-bottom: 0.8rem; }
h1 { font-family: 'Cormorant Garamond', serif; font-size: 2.4rem; font-weight: 300; color: #f0ead8; line-height: 1.2; margin-bottom: 0.5rem; }

.card { padding: 3rem; }
.subtitle { font-size: 15px; color: rgba(240,234,216,0.45); line-height: 1.6; margin-bottom: 2rem; }
.authors { display: flex; gap: 2rem; padding: 1.5rem 0; margin-bottom: 2rem; border-top: 1px solid rgba(184,146,58,0.15); border-bottom: 1px solid rgba(184,146,58,0.15); align-items: center; }
.author { display: flex; align-items: center; gap: 0.9rem; }
.author img { width: 60px; height: 60px; border-radius: 50%; object-fit: cover; object-position: center top; border: 2px solid rgba(184,146,58,0.5); filter: sepia(15%); }
.author-name { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; font-weight: 600; color: #fff8e8; display: block; }
.author-role { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: #d4aa5a; }
.sep { color: rgba(184,146,58,0.3); font-size: 1.5rem; }
.qlabel { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-style: italic; color: #f0ead8; margin-bottom: 1rem; display: block; }
.question { margin-bottom: 2rem; }
.options { display: flex; flex-direction: column; gap: 0.5rem; }
.option { display: flex; align-items: center; gap: 0.9rem; padding: 0.9rem 1.1rem; border: 1px solid rgba(184,146,58,0.2); background: transparent; cursor: pointer; text-align: left; font-family: 'Karla', sans-serif; font-size: 15px; font-weight: 300; color: rgba(240,234,216,0.75); position: relative; overflow: hidden; transition: all 0.18s; }
.option:hover { border-color: rgba(184,146,58,0.5); background: rgba(184,146,58,0.05); }
.option.selected { border-color: #b8923a; background: rgba(184,146,58,0.08); color: #f0ead8; }
.dot { width: 15px; height: 15px; border: 1.5px solid rgba(240,234,216,0.3); border-radius: 50%; flex-shrink: 0; transition: all 0.18s; position: relative; }
.option.selected .dot { border-color: #b8923a; background: #b8923a; }
.option.selected .dot::after { content:''; position:absolute; inset:3px; background:#0e0b06; border-radius:50%; }
.rbar-wrap { position:absolute; inset:0; pointer-events:none; opacity:0; transition:opacity 0.3s; }
.rbar { height:100%; background:rgba(184,146,58,0.08); transition:width 0.7s cubic-bezier(.4,0,.2,1); width:0%; }
.option.done .rbar-wrap { opacity:1; }
.pct { margin-left:auto; font-size:13px; color:#b8923a; font-weight:500; opacity:0; transition:opacity 0.3s; position:relative; white-space:nowrap; }
.option.done .pct { opacity:1; }
.olabel { position:relative; line-height:1.4; }
.osub { font-size:12px; color:rgba(240,234,216,0.4); display:block; margin-top:2px; }
hr { border:none; border-top:1px solid rgba(184,146,58,0.15); margin:1.8rem 0; }
.btn { margin-top:1.5rem; width:100%; padding:1rem 1rem; background:#b8923a; color:#0e0b06; border:none; font-family:'Karla',sans-serif; font-size:13px; letter-spacing:0.18em; text-transform:uppercase; cursor:pointer; transition:background 0.18s; font-weight:500; }
.btn:hover { background:#d4aa5a; }
.btn:disabled { background:rgba(240,234,216,0.1); color:rgba(240,234,216,0.3); cursor:default; }
.thankyou { display:none; text-align:center; padding:1.2rem 0 0.5rem; font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1.2rem; color:#b8923a; }
.total { text-align:center; font-size:12px; color:rgba(240,234,216,0.3); margin-top:0.6rem; opacity:0; transition:opacity 0.4s; }
.total.vis { opacity:1; }
.flink { display:block; text-align:center; font-size:12px; letter-spacing:0.12em; text-transform:uppercase; color:rgba(184,146,58,0.6); text-decoration:none; margin-top:1.8rem; transition:color 0.2s; }
.flink:hover { color:#b8923a; }
</style>
</head>
<body>
<div class="wrap">
  <a href="index.html" class="back">← Back to Collection</a>
  <div class="card">
    <div class="eyebrow">ASC · Object. Power. Culture.</div>
    <h1>Reader Poll</h1>
    <p class="subtitle">Three questions — help shape future issues of the newsletter.</p>
    <div class="authors">
      <div class="author">
        <img src="data:image/jpeg;base64," alt="Alex Schütz">
        <div><span class="author-name">Alex Schütz</span><span class="author-role">Collector</span></div>
      </div>
      <span class="sep">·</span>
      <div class="author">
        <img src="data:image/jpeg;base64," alt="Sonja Schromm">
        <div><span class="author-name">Sonja Schromm</span><span class="author-role">Author & Editor</span></div>
      </div>
    </div>
    <div class="question">
      <span class="qlabel">Which object has stayed with you the most?</span>
      <div class="options" id="o1">
        <button class="option" onclick="sel(1,'a',this)"><div class="rbar-wrap"><div class="rbar" id="b1a"></div></div><div class="dot"></div><span class="olabel">Cowrie Shell<span class="osub">3,000+ years of global circulation</span></span><span class="pct" id="p1a"></span></button>
        <button class="option" onclick="sel(1,'b',this)"><div class="rbar-wrap"><div class="rbar" id="b1b"></div></div><div class="dot"></div><span class="olabel">Katanga Cross<span class="osub">Copper that bought a wife — and became a nation's symbol</span></span><span class="pct" id="p1b"></span></button>
        <button class="option" onclick="sel(1,'c',this)"><div class="rbar-wrap"><div class="rbar" id="b1c"></div></div><div class="dot"></div><span class="olabel">Kissi Penny<span class="osub">Money with a soul — that breaks</span></span><span class="pct" id="p1c"></span></button>
        <button class="option" onclick="sel(1,'d',this)"><div class="rbar-wrap"><div class="rbar" id="b1d"></div></div><div class="dot"></div><span class="olabel">Chevron Bead<span class="osub">Venice's trade secret — 64 pieces in the collection</span></span><span class="pct" id="p1d"></span></button>
      </div>
    </div>
    <hr>
    <div class="question">
      <span class="qlabel">What would you like more of in future issues?</span>
      <div class="options" id="o2">
        <button class="option" onclick="sel(2,'a',this)"><div class="rbar-wrap"><div class="rbar" id="b2a"></div></div><div class="dot"></div><span class="olabel">Deep dives into single objects</span><span class="pct" id="p2a"></span></button>
        <button class="option" onclick="sel(2,'b',this)"><div class="rbar-wrap"><div class="rbar" id="b2b"></div></div><div class="dot"></div><span class="olabel">Connections to digital currency &amp; crypto today</span><span class="pct" id="p2b"></span></button>
        <button class="option" onclick="sel(2,'c',this)"><div class="rbar-wrap"><div class="rbar" id="b2c"></div></div><div class="dot"></div><span class="olabel">The collector's perspective — how objects are found</span><span class="pct" id="p2c"></span></button>
        <button class="option" onclick="sel(2,'d',this)"><div class="rbar-wrap"><div class="rbar" id="b2d"></div></div><div class="dot"></div><span class="olabel">Comparisons across continents &amp; time periods</span><span class="pct" id="p2d"></span></button>
      </div>
    </div>
    <hr>
    <div class="question">
      <span class="qlabel">Which region of the world interests you most?</span>
      <div class="options" id="o3">
        <button class="option" onclick="sel(3,'a',this)"><div class="rbar-wrap"><div class="rbar" id="b3a"></div></div><div class="dot"></div><span class="olabel">Africa</span><span class="pct" id="p3a"></span></button>
        <button class="option" onclick="sel(3,'b',this)"><div class="rbar-wrap"><div class="rbar" id="b3b"></div></div><div class="dot"></div><span class="olabel">Asia &amp; the Pacific</span><span class="pct" id="p3b"></span></button>
        <button class="option" onclick="sel(3,'c',this)"><div class="rbar-wrap"><div class="rbar" id="b3c"></div></div><div class="dot"></div><span class="olabel">The Americas</span><span class="pct" id="p3c"></span></button>
        <button class="option" onclick="sel(3,'d',this)"><div class="rbar-wrap"><div class="rbar" id="b3d"></div></div><div class="dot"></div><span class="olabel">All equally — I'm here for the global picture</span><span class="pct" id="p3d"></span></button>
      </div>
    </div>
    <button class="btn" id="sbtn" onclick="submit()" disabled>Submit answers</button>
    <div class="thankyou" id="ty">Thank you — your answers are in. ✦</div>
    <p class="total" id="tot"></p>
    <a href="https://sonjaschromm.substack.com/archive" class="flink" target="_blank">Browse the full archive ↗</a>
  </div>
</div>
<script>
const V={1:{a:14,b:11,c:18,d:9},2:{a:16,b:13,c:8,d:15},3:{a:21,b:12,c:7,d:17}};
const C={1:null,2:null,3:null};
function sel(q,o,el){
  if(C[q])return; C[q]=o;
  document.querySelectorAll('#o'+q+' .option').forEach(x=>x.classList.remove('selected'));
  el.classList.add('selected');
  document.getElementById('sbtn').disabled=!(C[1]&&C[2]&&C[3]);
}
function submit(){
  [1,2,3].forEach(q=>{V[q][C[q]]++;});
  [1,2,3].forEach(q=>{
    const t=Object.values(V[q]).reduce((a,b)=>a+b,0);
    ['a','b','c','d'].forEach(o=>{
      const p=Math.round(V[q][o]/t*100);
      document.getElementById('p'+q+o).textContent=p+'%';
      document.getElementById('b'+q+o).style.width=p+'%';
    });
    document.querySelectorAll('#o'+q+' .option').forEach(x=>{x.classList.add('done');x.style.cursor='default';});
  });
  const t=Object.values(V[1]).reduce((a,b)=>a+b,0);
  const tv=document.getElementById('tot');
  tv.textContent=t+' votes so far'; tv.classList.add('vis');
  document.getElementById('sbtn').style.display='none';
  document.getElementById('ty').style.display='block';
}
</script>
</body>
</html>
